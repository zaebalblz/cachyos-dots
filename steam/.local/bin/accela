#!/usr/bin/env bash
set -eu

INSTALL_DIR="$HOME/.local/share/ACCELA"
APPIMAGE="$INSTALL_DIR/ACCELA.AppImage"
RUNSH="$INSTALL_DIR/run.sh"
BIN="$INSTALL_DIR/ACCELA"

if [ -x "$APPIMAGE" ]; then
    exec "$APPIMAGE" "$@"
elif [ -x "$RUNSH" ]; then
    exec "$RUNSH" "$@"
elif [ -x "$BIN" ]; then
    exec "$BIN" "$@"
else
    echo "ACCELA not found in $INSTALL_DIR" >&2
    exit 1
fi
