{
  "id": "wallcards",
  "name": "Wallcards",
  "version": "0.0.3",
  "minNoctaliaVersion": "4.7.0",
  "author": "tonigineer",
  "official": false,
  "license": "MIT",
  "repository": "https://github.com/noctalia-dev/noctalia-plugins",
  "description": "A `lively` wallpaper selector.",
  "tags": [
    "Desktop",
    "Theming"
  ],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "animation_duration": 750,
      "background_color": null,
      "background_opacity": null,
      "cards_shown": 11,
      "card_height": 500,
      "card_spacing": 8,
      "card_strip_width": 80,
      "card_radius": 10,
      "filter_images": [
        "png",
        "jpg",
        "jpeg"
      ],
      "filter_videos": [
        "mp4",
        "mkv",
        "avi",
        "mov"
      ],
      "live_preview": false,
      "selected_filter": "images",
      "shear_factor": -0.25,
      "top_bar_height": 35,
      "top_bar_radius": 10
    }
  }
}
