{
    "id": "calibre-provider",
    "name": "Calibre Provider",
    "version": "1.3.2",
    "description": "Search for books in your Calibre library",
    "tags": ["Launcher"],
    "minNoctaliaVersion": "4.6.1",
    "author": "Krendil",
    "license": "MIT",
    "repository": "https://github.com/noctalia-dev/noctalia-plugins",
    "entryPoints": {
        "main": "Main.qml",
        "launcherProvider": "LauncherProvider.qml",
        "settings": "Settings.qml"
    },
    "dependencies": {
        "plugins": []
    },
    "metadata": {
        "commandPrefix": "cb",
        "defaultSettings": {
            "launcher": "xdg-open",
            "forceGrid": false,
            "recentlyOpenedMax": 36,
            "recentlyOpenedFiles": []
        }
    }
}
